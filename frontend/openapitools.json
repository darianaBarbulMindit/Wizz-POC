{
  "$schema": "node_modules/@openapitools/openapi-generator-cli/assets/schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.12.0"
  },
  "inputSpec": "../openapi/schema.yaml",
  "generatorName": "typescript-angular",
  "output": "src/app/api",
  "additionalProperties": {
    "ngVersion": "20.0.0",
    "supportsES6": true,
    "withInterfaces": true,
    "useSingleRequestParameter": true,
    "fileNaming": "kebab-case",
    "enumNameSuffix": "Enum",
    "providedIn": "root"
  }
}
